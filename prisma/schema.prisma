// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum CollectionView {
  PRIVATE
  PUBLIC
}

enum PostMedium {
  DIGITAL
  OIL_PAINT
  WATERCOLOR
  PHOTOGRAPHY
  ILLUSTRATION
  SCULPTURE
  MIXED_MEDIA
  SKETCH
  THREE_D
  ANIMATION
  LINEART
  CONCEPT_ART
  ANIME_ART
  MANGA_ART
  PIXEL_ART
  TRADITIONAL_ART
  OTHER
}

model User {
  id             String    @id
  role           Role      @default(USER)
  name           String
  username       String    @unique
  email          String    @unique
  profileCreated Boolean   @default(false)
  emailVerified  Boolean   @default(false)
  image          String?   @default("https://res.cloudinary.com/dailhnvvl/image/upload/v1771605999/pfpdefault_omrkpw.png")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  sessions       Session[]
  accounts       Account[]
  profile       Profile?

  @@index([id])
  @@index([email])
  @@index([username])
  @@map("user")
}

model Profile {
  profileId   String       @id @unique
  user        User         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  bio         String?
  portfolio   String?
  location    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now())
  followers   Follow[]     @relation("followers")
  following   Follow[]     @relation("following")
  artPosts    Post[]
  collections Collection[]
  likes       Like[]
  comments    Comment[]

  @@index([profileId])
  @@map("profile")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Follow {
  followerId  String
  followingId String

  follower  Profile @relation("following", fields: [followerId], references: [profileId], onDelete: Cascade)
  following Profile @relation("followers", fields: [followingId], references: [profileId], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follow")
}

model Post {
  id          String       @id @default(uuid())
  authorId    String
  user        Profile      @relation(fields: [authorId], references: [profileId], onDelete: Cascade)
  title       String
  artImages   PostImages[]
  tags        String[]
  inPortfolio Boolean      @default(false)
  mediums     PostMedium[]
  description String?
  likes       Like[]
  Collections Collection[]
  comments    Comment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now())

  @@index([id])
  @@index([authorId])
  @@index([createdAt(sort: Desc)])
  @@map("post")
}

model PostImages {
  id            String   @id @default(uuid())
  postId        String
  url           String
  isAIGenerated Boolean  @default(false)
  artPost       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  order         Int
  createdAt     DateTime @default(now())

  @@unique([postId, order])
  @@index([id])
  @@index([postId, order])
  @@map("post_images")
}

model Collection {
  id      String         @id @default(uuid())
  name    String
  ownerId String
  view    CollectionView @default(PUBLIC)
  user    Profile        @relation(fields: [ownerId], references: [profileId], onDelete: Cascade)
  posts   Post[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@index([id])
  @@index([ownerId])
  @@map("collection")
}

model Like {
  artPostId String
  ownerId   String
  artPost   Post     @relation(fields: [artPostId], references: [id], onDelete: Cascade)
  user      Profile  @relation(fields: [ownerId], references: [profileId], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([artPostId, ownerId])
  @@index([artPostId])
  @@index([ownerId])
  @@map("like")
}

model Comment {
  id        String    @id @default(uuid())
  artPostId String
  ownerId   String
  likes     Int       @default(0)
  replies   Comment[] @relation("replies")
  artPost   Post      @relation(fields: [artPostId], references: [id], onDelete: Cascade)
  user      Profile   @relation(fields: [ownerId], references: [profileId], onDelete: Cascade)
  comment   Comment?  @relation("replies", fields: [commentId], references: [id])
  commentId String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now())

  @@index([id])
  @@index([artPostId, ownerId])
  @@map("comment")
}
